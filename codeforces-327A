#include <bits/stdc++.h>
using namespace std;

int main(){
    int n;
    cin>>n;

    vector<int>a(n);
    int ones=0;

    for(int i=0;i<n;i++){
        cin>>a[i];
        if(a[i]==1) ones++;
    }

    int max_sum=0,curr=0;

    for(int i=0;i<n;i++){
        if(a[i]==0) curr+=1;
        else curr-=1;

        curr=max(curr,0);
        max_sum=max(max_sum,curr);
    }

    if(max_sum==0) cout<<n-1;
    else cout<<ones+max_sum;

    return 0;
}
